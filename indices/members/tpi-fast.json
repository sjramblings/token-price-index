{
  "name": "tpi-fast",
  "description": "Fast-tier capability index. Mechanical split of ATPI's 16 members: blended < $1/M tokens. 4 members spanning Mistral, MiniMax, OpenAI, DeepSeek — the cost-optimised end of the frontier set. Reproducible from indices/members/atpi-replica.json without editorial judgment.",
  "blend": { "input": 0.7, "output": 0.3 },
  "tier": "fast",
  "selection_rule": "members from atpi-replica with published_blended_per_million < 1.00",
  "members": [
    {
      "label": "Mistral Large 3",
      "select": [
        { "source": "litellm", "family": "mistral-large", "model_id_equals": "openrouter/mistralai/mistral-large-2512" },
        { "source": "aws-pricelist", "family": "mistral-large-3", "model_id_equals": "mistral-large-3", "region": "us-east-1" }
      ],
      "published_blended_per_million": 0.80,
      "note": "Mistral Large 3 (mistral-large-2512) is the December 2025 release; Mistral hasn't published direct API pricing in our LiteLLM source. Falls back to Bedrock us-east-1."
    },
    {
      "label": "MiniMax M2.7",
      "select": [
        { "source": "openrouter", "family": "minimax-m2.7", "model_id_equals": "minimax/minimax-m2.7" },
        { "source": "litellm", "family": "minimax-m2.7", "model_id_equals": "sambanova/MiniMax-M2.7" }
      ],
      "published_blended_per_million": 0.57
    },
    {
      "label": "GPT-5.4 Nano",
      "select": [
        { "source": "openrouter", "family": "gpt-5.4-nano", "model_id_equals": "openai/gpt-5.4-nano" }
      ],
      "published_blended_per_million": 0.515
    },
    {
      "label": "DeepSeek V4 Flash",
      "select": [
        { "source": "openrouter", "family": "deepseek-v4-flash", "model_id_equals": "deepseek/deepseek-v4-flash" }
      ],
      "published_blended_per_million": 0.182
    }
  ]
}
